{
   "compilerOptions": {
      "target": "ES2020",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "rootDir": "./src",
      "outDir": "./lib",
      "noImplicitAny": false,
      "skipLibCheck": true,
      "noEmit": true,
      "types": ["node", "vitest/globals"]
   },
   "exclude": ["node_modules", "**/*.test.ts", "vitest.config.ts"]
}
